# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: postgresql+psycopg2://careai:careai@localhost:5432/careai
# Railway:    will inject DATABASE_URL automatically (postgres://...)
#
# IMPORTANT — special characters in password:
#   If your password contains @ : / # ? &  → URL-ENCODE them:
#     @ → %40    : → %3A    / → %2F    # → %23    ? → %3F    & → %26
#   Example password "Manha3321@" becomes:
#     postgresql+psycopg2://careAidb:Manha3321%40@localhost:5432/careAidb
#   Or simpler: use a password with letters and digits only.
DATABASE_URL=postgresql+psycopg2://careai:careai@localhost:5432/careai

# ─── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── AI Provider Config ───────────────────────────────────────────────────────
# Primary: Ollama (local). Falls back to Groq automatically on failure.
# ─── AI Providers ────────────────────────────────────────────────────────────
# Architecture: Groq is PRIMARY (fast cloud), Ollama is FALLBACK (local).
# This gives fast UX in normal use, with offline capability if Groq fails.

# Groq (PRIMARY) — get free key at https://console.groq.com (no card required)
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# Ollama (FALLBACK) — local LLM server
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_TEXT_MODEL=gemma3:4b
OLLAMA_HEALTHCHECK_TIMEOUT=3
OLLAMA_REQUEST_TIMEOUT=120

# Force a provider (auto | groq | ollama). Default = auto (Groq primary, Ollama fallback).
# Set to "ollama" for offline-only mode (skips Groq entirely).
# Set to "groq" for cloud-only mode (skips Ollama fallback).
AI_PROVIDER=auto

# ─── Limits ───────────────────────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=100

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Optional: SMS alerts on fall detection ───────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Optional: Fall Detection ML Service (Hugging Face Space) ─────────────
# Set this in production to delegate ML to a remote service so the main
# backend stays light. Leave empty for local fall detection (requires
# requirements-ml.txt to be installed).
# Example: https://yourusername-careai-falldetect.hf.space
FALL_DETECT_SERVICE_URL=
FALL_DETECT_SERVICE_API_KEY=

# ─── Optional: Email notifications ────────────────────────────────────────────
# Notifications are always shown in the in-app bell. Email is OPTIONAL.
# If you leave SMTP_* empty, only in-app + browser notifications work.
#
# Gmail setup (recommended):
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Create an "App Password" (requires 2-Step Verification on)
#   3. Use the 16-char app password below as SMTP_PASSWORD
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ─── Reminder scheduler ──────────────────────────────────────────────────────
# Background job that checks routines every 60s and creates notifications
# when scheduled_at matches the current time. Set to false to disable.
ENABLE_REMINDER_SCHEDULER=true
REMINDER_CHECK_INTERVAL=60
